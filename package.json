{
  "name": "dayflow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "vite",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build:react": "vite build",
    "build:electron": "electron-builder",
    "build": "npm run build:react && npm run build:electron",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.dayflow.app",
    "productName": "DayFlow",
    "icon": "public/icon-512.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs",
      "public/icon-512.png"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon-512.png"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "auto-launch": "^5.0.6",
    "electron-store": "^11.0.2",
    "node-schedule": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.8.1",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.8",
    "wait-on": "^9.0.5"
  }
}